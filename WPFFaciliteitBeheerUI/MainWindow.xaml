<Window x:Class="WPFFaciliteitBeheerUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFFaciliteitBeheerUI"
        mc:Ignorable="d"
        Title="Facility Management" Height="450" Width="800" WindowStyle="None" Background="#1F2129" AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#252836" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" VerticalAlignment="Top">
            <TextBlock Text="Facility Management" Foreground="#F5F7FB" Margin="10,0,0,0" 
                       VerticalAlignment="Center" HorizontalAlignment="Left" FontWeight="SemiBold"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource WindowControlButton}" 
                        Content="&#xE921;" Click="MinimizeButton_Click"/>
                <Button Style="{StaticResource WindowControlButton}" 
                        Content="&#xE922;" Click="MaximizeRestoreButton_Click" x:Name="MaxRestoreButton"/>
                <Button Style="{StaticResource WindowControlButton}" 
                        Content="&#xE8BB;" Click="CloseButton_Click" 
                        Background="Transparent">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)"
                                                    To="#E81123" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)"
                                                    To="Transparent" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>
            </StackPanel>
        </Grid>

        <DataGrid Grid.Row="1" Name="DataGridFacilities" Margin="5"
                  Background="#2A2D3E"
                  Foreground="#F5F7FB"
                  AlternatingRowBackground="#252836"
                  RowBackground="#2A2D3E"
                  GridLinesVisibility="None"
                  HeadersVisibility="Column"
                  BorderThickness="0"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  AutoGenerateColumns="True">

            <DataGrid.Resources>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontFamily" Value="Segoe UI"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#3B3F58"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#6C5CE7"/>
                            <Setter Property="Foreground" Value="#F5F7FB"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
                
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#252836"/>
                    <Setter Property="Foreground" Value="#F5F7FB"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="BorderBrush" Value="#2A2D3E"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Add Facility" Click="AddFacility_Click"/>
                    <MenuItem Header="Update Facility" Click="UpdateFacility_Click"/>
                    <MenuItem Header="Delete Facility" Click="DeleteFacility_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>
    </Grid>
</Window>
