<Window x:Class="WPFRouteBeheerUI.RouteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFRouteBeheerUI"
        mc:Ignorable="d"
        Title="Route Management" Height="600" Width="900"
        WindowStyle="None" AllowsTransparency="True" Background="#1F2129">

    <Window.Resources>
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="#6C5CE7"/>
            <Setter Property="Foreground" Value="#F5F7FB"/>
            <Setter Property="BorderBrush" Value="#252836"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Foreground" Value="#F5F7FB"/>
            <Setter Property="Background" Value="#1F2129"/>
            <Setter Property="RowBackground" Value="#2A2D3E"/>
            <Setter Property="AlternatingRowBackground" Value="#1F1F2D"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="BorderBrush" Value="#252836"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Foreground" Value="#F5F7FB"/>
                        <Setter Property="Background" Value="#252836"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Cursor" Value="Hand"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#F5F7FB"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2A2D3E"/>
            <Setter Property="Foreground" Value="#F5F7FB"/>
            <Setter Property="BorderBrush" Value="#252836"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,0"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#2A2D3E"/>
            <Setter Property="Foreground" Value="#F5F7FB"/>
            <Setter Property="BorderBrush" Value="#252836"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#252836" BorderThickness="1" Background="#1F2129" CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <!-- Top Bar -->
                <RowDefinition Height="*"/>
                <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Grid Grid.Row="0" Background="#252836" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="Route Management" Foreground="#F5F7FB" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource WindowControlButton}" Content="&#xE8BB;" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- Main Content -->
            <Grid Grid.Row="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Route Details -->
                <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0" Content="ID:" Margin="0,0,5,0"/>
                    <TextBox Grid.Column="1" Name="TxtId" IsReadOnly="True"/>

                    <Label Grid.Column="2" Content="Name:" Margin="20,0,5,0"/>
                    <TextBox Grid.Column="3" Name="TxtName"/>

                    <Label Grid.Column="4" Content="Full Distance:" Margin="20,0,5,0"/>
                    <TextBox Grid.Column="5" Name="TxtDistance" IsReadOnly="True"/>
                </Grid>

                <!-- Network Points and Stops DataGrid -->
                <DataGrid Grid.Row="1" Grid.Column="0" Name="DataGridStops" 
          AutoGenerateColumns="False" Margin="0,0,10,0"
          HeadersVisibility="Column" CanUserAddRows="False" 
          CanUserDeleteRows="False" SelectionMode="Single"
          SelectionChanged="DataGridStops_SelectionChanged"
          ItemsSource="{Binding Stops}">

                    <!-- Context menu for entire DataGrid -->
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Remove Point" Click="RemovePoint_Click"/>
                            <MenuItem Header="Add Point to front" Click="AddToFront_Click"/>
                            <MenuItem Header="Add Point to end" Click="AddToEnd_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                    <DataGrid.Columns>
                        <!-- Centered Point ID -->
                        <DataGridTextColumn Header="Point ID" Binding="{Binding Id}" IsReadOnly="True" Width="auto">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Centered X -->
                        <DataGridTextColumn Header="X" Binding="{Binding X}" IsReadOnly="True" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Centered Y -->
                        <DataGridTextColumn Header="Y" Binding="{Binding Y}" IsReadOnly="True" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Stop indicator with colored circle -->
                        <DataGridTemplateColumn Header="Is Stop" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Name="StopIndicator"
                            Width="20" Height="20" CornerRadius="10"
                            HorizontalAlignment="Center"
                            MouseLeftButtonDown="StopIndicator_MouseLeftButtonDown">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsStop}" Value="True">
                                                        <Setter Property="Background" Value="#4CD137"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsStop}" Value="False">
                                                        <Setter Property="Background" Value="#E84118"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>



                <!-- Facilities List -->
                <Grid Grid.Row="1" Grid.Column="1" Margin="10,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Content="Facilities at Selected Point" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                    <ListBox Grid.Row="1" Name="ListBoxFacilities" DisplayMemberPath="Name"/>
                </Grid>

                <!-- Buttons -->
                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="Save Changes" Style="{StaticResource ActionButton}" Click="SaveChanges_Click"/>
                    <Button Grid.Column="1" Content="Save to File" Style="{StaticResource ActionButton}" Click="SaveToFile_Click"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>