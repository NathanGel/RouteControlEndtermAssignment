<Window x:Class="WPFRouteBeheerUI.RouteNameDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enter Route Name" Height="200" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#1F2129"
        AllowsTransparency="True"
        BorderThickness="1"
        BorderBrush="#252836">

    <Border CornerRadius="8" Background="#1F2129" Padding="20" BorderBrush="#252836" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Enter a name for the new route:"
                       Foreground="#F5F7FB"
                       FontSize="16"
                       Margin="0,0,0,10"/>

            <TextBox x:Name="TxtRouteName"
                     Grid.Row="1"
                     FontSize="14"
                     Background="#2A2D3E"
                     Foreground="#F5F7FB"
                     BorderBrush="#252836"
                     BorderThickness="1"
                     Padding="5"
                     Height="30"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Cancel" Width="80" Margin="0,0,10,0"
                        Click="BtnCancel_Click"
                        Background="#2A2D3E"
                        Foreground="#F5F7FB"
                        BorderBrush="#252836"
                        Height="30"/>
                <Button Content="OK" Width="80"
                        Click="BtnOk_Click"
                        Background="#6C5CE7"
                        Foreground="#F5F7FB"
                        BorderBrush="#252836"
                        Height="30"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
