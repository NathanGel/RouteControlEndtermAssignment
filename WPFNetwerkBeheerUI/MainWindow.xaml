<Window x:Class="WPFNetwerkBeheerUI.MainWindow"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
       xmlns:local="clr-namespace:WPFNetwerkBeheerUI"
       mc:Ignorable="d"
       Title="Network Management" Height="660" Width="570"
       WindowStyle="None" AllowsTransparency="True" Background="Transparent">
 
    <Window.Resources>
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#252836" BorderThickness="1" Background="#1F2129">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- De custom top Bar -->
            <Grid Background="#252836" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="Network Management" Foreground="#F5F7FB" Margin="10,0,0,0"
                           VerticalAlignment="Center" HorizontalAlignment="Left" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource WindowControlButton}"
                            Content="&#xE921;" Click="MinimizeButton_Click"/>
                    <Button Style="{StaticResource WindowControlButton}"
                            Content="&#xE922;" Click="MaximizeRestoreButton_Click" x:Name="MaxRestoreButton"/>
                    <Button Style="{StaticResource WindowControlButton}"
                            Content="&#xE8BB;" Click="CloseButton_Click" Background="Transparent">
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="Button.MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)"
                                                        To="#E81123" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)"
                                                        To="Transparent" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Name="TextBlockConnection"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           FontSize="20"
                           Foreground="Red"/>

                <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right">
                    <Button Content="Add Connection" Click="AddConnection_Click"
                            Background="#6C5CE7" Foreground="#F5F7FB" BorderBrush="#252836"
                            Margin="5" BorderThickness="1" Height="30" Width="130"/>
                    <Button Content="Remove Connection" Click="RemoveConnection_Click"
                            Background="#E81123" Foreground="White" BorderBrush="#A80000"
                            Margin="5" BorderThickness="1" Height="30" Width="130"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2">
                <Canvas Name="canvas" Width="550" Height="550"
                        Background="#2A2D3E" Margin="10"
                        MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                        MouseRightButtonDown="Canvas_MouseRightButtonDown">
                    <Canvas.ContextMenu>
                        <ContextMenu Name="contextMenu">
                            <MenuItem Name="MenuItemAddNetworkPoint" Header="Add NetworkPoint" Click="AddNetworkPoint_Click"/>
                            <MenuItem Name="MenuItemRemoveNetworkPoint" Header="Remove NetworkPoint" Click="RemoveNetworkPoint_Click"/>
                            <MenuItem Name="MenuItemUpdateNetworkPoint" Header="Update NetworkPoint" Click="UpdateNetworkPoint_Click"/>
                        </ContextMenu>
                    </Canvas.ContextMenu>
                </Canvas>
            </Grid>
        </Grid>
    </Border>
</Window>
