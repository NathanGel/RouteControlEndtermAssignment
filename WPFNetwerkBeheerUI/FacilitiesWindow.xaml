<Window x:Class="WPFNetwerkBeheerUI.FacilitiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFNetwerkBeheerUI"
        mc:Ignorable="d"
        Title="FacilitiesWindow" Height="450" Width="800"
        WindowStyle="None" AllowsTransparency="True" Background="#1F2129">

    <Window.Resources>
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#252836" BorderThickness="1" Background="#1F2129" CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- De custom Top Bar -->
            <Grid Grid.Row="0" Background="#252836" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="Facilities" Foreground="#F5F7FB" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource WindowControlButton}" Content="&#xE8BB;" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Label Content="Selected Facilities" Grid.Column="0" Foreground="#F5F7FB" Margin="5" HorizontalAlignment="Center"/>
                <ListBox SelectionMode="Extended" Grid.Row="2" Grid.Column="0" Name="ListBoxSelectedFacilities" Margin="5"
                         DisplayMemberPath="Name" Background="#2A2D3E" Foreground="#F5F7FB" BorderBrush="#252836"/>

                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Margin="5">
                    <Button Content="&gt;" Margin="5" Click="RemoveFacility_Click" 
            Background="#6C5CE7" Foreground="#F5F7FB" BorderBrush="#252836" Height="30" Width="60" BorderThickness="1"/>
                    <Button Content="&lt;" Margin="5" Click="AddFacility_Click"
            Background="#6C5CE7" Foreground="#F5F7FB" BorderBrush="#252836" Height="30" Width="60" BorderThickness="1"/>
                    <Button Content="&gt;&gt;" Margin="5" Click="RemoveAllFacilities_Click"
            Background="#6C5CE7" Foreground="#F5F7FB" BorderBrush="#252836" Height="30" Width="60" BorderThickness="1"/>
                    <Button Content="&lt;&lt;" Margin="5" Click="AddAllFacilities_Click"
            Background="#6C5CE7" Foreground="#F5F7FB" BorderBrush="#252836" Height="30" Width="60" BorderThickness="1"/>
                </StackPanel>



                <Label Content="All Facilities" Grid.Column="2" Foreground="#F5F7FB" Margin="5" HorizontalAlignment="Center"/>
                <ListBox SelectionMode="Extended" Grid.Row="2" Grid.Column="2" Name="ListBoxAllFacilities" Margin="5"
                         DisplayMemberPath="Name" Background="#2A2D3E" Foreground="#F5F7FB" BorderBrush="#252836"/>

                <Button Grid.Row="3" Grid.Column="0" Margin="5" Content="Add" Grid.ColumnSpan="3" Click="BtnAdd_Click"
                        Background="#6C5CE7" Foreground="#F5F7FB" BorderBrush="#252836" Height="30"/>
            </Grid>
        </Grid>
    </Border>
</Window>
